<%- include('../partials/head', {title: 'مصمم بطاقة التجهيز'}) %>

<style>
.designer-wrap { max-width: 1100px; margin: 0 auto; }
.page-header { margin-bottom: 20px; }
.page-header h2 { font-size: 1.3rem; font-weight: 900; color: #1a2d4a; margin-bottom: 4px; }
.page-header p  { color: #888; font-size: .88rem; margin: 0; }

.alert-success {
  background: #d1fae5; border: 1.5px solid #6ee7b7; color: #065f46;
  border-radius: 10px; padding: 10px 16px; margin-bottom: 16px; font-size: .88rem;
}

.designer-layout { display: grid; grid-template-columns: 1fr 320px; gap: 20px; align-items: start; }
@media (max-width: 860px) { .designer-layout { grid-template-columns: 1fr; } }

.sec-card {
  background: #fff; border-radius: 14px; box-shadow: 0 2px 10px rgba(0,0,0,.07);
  margin-bottom: 16px; overflow: hidden;
}
.sec-title {
  background: #f8fafc; border-bottom: 1px solid #e8ecf0;
  padding: 13px 18px; font-weight: 800; font-size: .88rem; color: #1a2d4a;
  display: flex; align-items: center; gap: 8px;
}
.toggle-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
@media (max-width: 600px) { .toggle-grid { grid-template-columns: 1fr; } }

.toggle-row {
  display: flex; align-items: center; gap: 12px; padding: 12px 18px;
  border-bottom: 1px solid #f5f5f5; transition: background .12s;
}
.toggle-row:hover { background: #fafbff; }
.toggle-row:last-child { border-bottom: none; }
.toggle-row .tr-icon  { font-size: 1.1rem; flex-shrink: 0; }
.toggle-row .tr-label { font-size: .85rem; font-weight: 700; color: #333; flex: 1; }
.toggle-row .tr-sub   { font-size: .72rem; color: #999; }

/* Toggle */
.toggle-switch { position: relative; display: inline-block; width: 42px; height: 23px; flex-shrink:0; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider {
  position: absolute; inset: 0; background: #e5e7eb; border-radius: 23px; cursor: pointer; transition: background .2s;
}
.toggle-slider::before {
  content: ''; position: absolute; width: 17px; height: 17px; left: 3px; top: 3px;
  background: #fff; border-radius: 50%; transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2);
}
.toggle-switch input:checked + .toggle-slider { background: #10b981; }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(19px); }

/* Number / select inputs */
.ctrl-row { display: flex; align-items: center; gap: 12px; padding: 12px 18px; border-bottom: 1px solid #f5f5f5; }
.ctrl-row:last-child { border-bottom: none; }
.ctrl-row .cr-label { font-size: .85rem; font-weight: 700; color: #333; flex: 1; }
.ctrl-row .cr-sub   { font-size: .72rem; color: #999; }
.ctrl-select, .ctrl-number {
  padding: 7px 12px; border-radius: 8px; border: 1.5px solid #d0d8e0;
  font-family: 'Tajawal', sans-serif; font-size: .85rem; background: #fff;
  min-width: 120px;
}
.ctrl-number { width: 80px; min-width: 60px; }

/* Save bar */
.save-bar {
  position: sticky; bottom: 0; background: #fff; border-top: 2px solid #e8ecf0;
  padding: 14px 20px; display: flex; gap: 12px; align-items: center;
  box-shadow: 0 -4px 12px rgba(0,0,0,.08); z-index: 50; margin-top: 4px;
}
.btn-save {
  background: linear-gradient(135deg, #1a2d4a, #2d4a6e); color: #fff; border: none;
  border-radius: 10px; padding: 11px 28px; font-weight: 800; font-size: .9rem;
  font-family: 'Tajawal', sans-serif; cursor: pointer; transition: opacity .15s;
}
.btn-save:hover { opacity: .88; }
.btn-cancel { color: #888; text-decoration: none; font-size: .88rem; font-weight: 600; }
.btn-reset-all {
  color: #dc3545; font-size: .82rem; font-weight: 700; background: none; border: none;
  cursor: pointer; font-family: 'Tajawal', sans-serif; margin-right: auto;
}

/* ── Preview card ── */
.preview-sticky { position: sticky; top: 80px; }
.preview-card-wrap {
  background: #fff; border-radius: 14px; box-shadow: 0 2px 10px rgba(0,0,0,.07);
  overflow: hidden;
}
.preview-title {
  background: #f8fafc; border-bottom: 1px solid #e8ecf0;
  padding: 12px 16px; font-weight: 800; font-size: .85rem; color: #1a2d4a;
}
.preview-body { padding: 12px; }

.pv-card {
  border: 1.5px solid #ccc; border-radius: 8px; overflow: hidden;
  background: #fff; font-size: .75rem; max-width: 200px; margin: 0 auto;
}
.pv-header { background: #1a2d4a; color: #fff; padding: 5px 7px; display: flex; justify-content: space-between; align-items: center; }
.pv-order  { font-family: monospace; font-weight: 700; font-size: .72rem; }
.pv-badge  { font-size: .55rem; background: #0d6efd; color: #fff; border-radius: 8px; padding: 1px 5px; font-weight:700; }
.pv-stage  { background: #f0f4ff; border-bottom: 1px solid #e0e8f5; padding: 3px 7px; font-size: .62rem; color: #1a2d4a; font-weight: 700; display: flex; gap: 4px; align-items: center; }
.pv-dot    { width: 6px; height: 6px; border-radius: 50%; background: #c9a24b; }
.pv-body   { display: flex; gap: 5px; padding: 5px; }
.pv-img    { width: 42px; height: 42px; background: linear-gradient(135deg, #1a2d4a, #2d4a6e); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
.pv-info   { flex: 1; min-width: 0; }
.pv-name   { font-weight: 700; font-size: .72rem; color: #1a2d4a; margin-bottom: 3px; }
.pv-chips  { display: flex; gap: 2px; flex-wrap: wrap; }
.pv-chip   { background: #f0f4ff; color: #2d5096; border-radius: 3px; padding: 0 4px; font-size: .6rem; font-weight: 600; line-height: 1.5; }
.pv-rows   { padding: 0 7px 4px; }
.pv-row    { display: flex; justify-content: space-between; font-size: .62rem; padding: 1px 0; border-bottom: 1px solid #f5f5f5; }
.pv-row:last-child { border-bottom: none; }
.pv-lbl    { color: #aaa; }
.pv-qr     { padding: 5px; display: flex; justify-content: center; }
.pv-qr-box { width: 44px; height: 44px; background: #f4f6f9; border: 1px solid #e0e0e0; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
.pv-notes  { margin: 0 5px 4px; background: #fffbf0; border: 1px dashed #e8c96a; border-radius: 4px; padding: 2px 5px; font-size: .6rem; color: #6b5000; }
.pv-check  { border-top: 1px dashed #e0e0e0; padding: 3px 7px 4px; }
.pv-check div { font-size: .58rem; color: #666; padding: 1px 0; }
.pv-check span { display: inline-block; width: 8px; height: 8px; border: 1px solid #999; border-radius: 2px; margin-left: 4px; }

.preview-info { text-align: center; font-size: .75rem; color: #888; margin-top: 10px; }
</style>

<div class="designer-wrap">
  <div class="page-header">
    <a href="/admin" style="color:#c9a24b;text-decoration:none;font-size:.85rem;font-weight:700">← لوحة التحكم</a>
    <h2 style="margin-top:6px">🗂️ مصمم بطاقة التجهيز</h2>
    <p>خصص محتوى بطاقات التجهيز. تُطبَّق الإعدادات تلقائياً عند الطباعة.</p>
  </div>

  <% if (success) { %><div class="alert-success">✅ <%= success %></div><% } %>

  <form method="POST" action="/admin/card-designer" id="designer-form">
  <div class="designer-layout">

    <!-- ── Left: controls ── -->
    <div>

      <!-- Field visibility -->
      <div class="sec-card">
        <div class="sec-title">👁️ إظهار / إخفاء الحقول</div>
        <div class="toggle-grid">
          <%
          const toggleFields = [
            { f:'show_image',            icon:'🖼️', label:'صورة المنتج',      sub:'Product Image' },
            { f:'show_order_number',     icon:'🔢', label:'رقم الطلب',         sub:'Order Number' },
            { f:'show_product_name',     icon:'👗', label:'اسم المنتج',        sub:'Product Name' },
            { f:'show_sku',              icon:'🏷️', label:'كود SKU / باركود', sub:'SKU / Barcode' },
            { f:'show_size',             icon:'📐', label:'المقاس',            sub:'Size' },
            { f:'show_color',            icon:'🎨', label:'اللون',             sub:'Color' },
            { f:'show_quantity',         icon:'🔢', label:'الكمية',            sub:'Quantity' },
            { f:'show_pieces_count',     icon:'📦', label:'إجمالي القطع',     sub:'Pieces Count' },
            { f:'show_type_badge',       icon:'🏷️', label:'شارة النوع',       sub:'Type Badge (إنتاج/مخزون)' },
            { f:'show_stage',            icon:'📊', label:'شريط المرحلة',     sub:'Stage Strip' },
            { f:'show_qr',               icon:'📱', label:'رمز QR',           sub:'QR Code' },
            { f:'show_barcode_text',     icon:'🔡', label:'نص الباركود',      sub:'Barcode Text' },
            { f:'show_embroidery',       icon:'🧵', label:'تفاصيل التطريز',   sub:'Embroidery Details' },
            { f:'show_production_notes', icon:'📝', label:'ملاحظات الإنتاج', sub:'Production Notes' },
            { f:'show_checklist',        icon:'✅', label:'قائمة التحقق',     sub:'Checklist' },
          ];
          %>
          <% toggleFields.forEach(function(t) { %>
          <div class="toggle-row">
            <span class="tr-icon"><%= t.icon %></span>
            <div style="flex:1">
              <div class="tr-label"><%= t.label %></div>
              <div class="tr-sub"><%= t.sub %></div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" name="<%= t.f %>"
                onchange="updatePreview()"
                data-field="<%= t.f %>"
                <%= cardSettings[t.f] !== false ? 'checked' : '' %>>
              <span class="toggle-slider"></span>
            </label>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Card layout settings -->
      <div class="sec-card">
        <div class="sec-title">📄 إعدادات التخطيط والطباعة</div>

        <div class="ctrl-row">
          <div style="flex:1">
            <div class="cr-label">عدد البطاقات في الصفحة</div>
            <div class="cr-sub">افتراضي عند فتح صفحة الطباعة</div>
          </div>
          <select class="ctrl-select" name="default_layout">
            <option value="12" <%= cardSettings.default_layout == 12 ? 'selected' : '' %>>12 بطاقة (3×4)</option>
            <option value="16" <%= cardSettings.default_layout == 16 ? 'selected' : '' %>>16 بطاقة (4×4)</option>
          </select>
        </div>

        <div class="ctrl-row">
          <div style="flex:1">
            <div class="cr-label">هامش الطباعة (ملم)</div>
            <div class="cr-sub">المسافة بين البطاقات والحواف</div>
          </div>
          <input type="number" class="ctrl-number" name="margin_mm"
            value="<%= cardSettings.margin_mm || 2 %>" min="0" max="10" step="0.5">
        </div>

        <div class="ctrl-row">
          <div style="flex:1">
            <div class="cr-label">حجم رمز QR</div>
            <div class="cr-sub">القياس الظاهر في بطاقة الطباعة</div>
          </div>
          <select class="ctrl-select" name="qr_size">
            <option value="small"  <%= cardSettings.qr_size === 'small'  ? 'selected' : '' %>>صغير (56px)</option>
            <option value="medium" <%= cardSettings.qr_size === 'medium' || !cardSettings.qr_size ? 'selected' : '' %>>متوسط (76px)</option>
            <option value="large"  <%= cardSettings.qr_size === 'large'  ? 'selected' : '' %>>كبير (96px)</option>
          </select>
        </div>
      </div>

      <!-- QR info -->
      <div class="sec-card">
        <div class="sec-title">📱 إعدادات QR Code</div>
        <div style="padding:14px 18px;font-size:.84rem;color:#555;line-height:1.7">
          <div style="margin-bottom:8px">✅ <strong>QR مرتبط بالطلب:</strong> يُشفِّر الرابط الكامل <code dir="ltr">/scanner/item/{barcode}</code></div>
          <div style="margin-bottom:8px">✅ <strong>يعمل عبر كل المراحل:</strong> نفس الرمز لكل مرحلة إنتاجية</div>
          <div style="margin-bottom:8px">✅ <strong>يُقرأ من أي هاتف:</strong> يفتح صفحة الماسح مباشرة</div>
          <div>⚙️ لضبط الرابط الأساسي في الإنتاج، عيّن متغير البيئة <code>APP_BASE_URL</code></div>
        </div>
      </div>

      <div class="save-bar">
        <button type="button" class="btn-reset-all" onclick="resetAll()">↩ إعادة الافتراضيات</button>
        <a href="/admin" class="btn-cancel">إلغاء</a>
        <button type="submit" class="btn-save">💾 حفظ الإعدادات</button>
      </div>
    </div>

    <!-- ── Right: live preview ── -->
    <div class="preview-sticky">
      <div class="preview-card-wrap">
        <div class="preview-title">👁️ معاينة البطاقة (مثال)</div>
        <div class="preview-body">
          <div class="pv-card" id="preview-card">

            <div class="pv-header" id="pv-header">
              <span class="pv-order" id="pv-order-num">LMS-1001</span>
              <span class="pv-badge" id="pv-type-badge">إنتاج</span>
            </div>

            <div class="pv-stage" id="pv-stage">
              <span class="pv-dot"></span> المرحلة: تجهيز
            </div>

            <div class="pv-body">
              <div class="pv-img" id="pv-img">👗</div>
              <div class="pv-info">
                <div class="pv-name" id="pv-name">برقع مطرز</div>
                <div class="pv-chips">
                  <span class="pv-chip" id="pv-size">M</span>
                  <span class="pv-chip" id="pv-color">أبيض</span>
                  <span class="pv-chip" id="pv-qty">الكمية: 3</span>
                  <span class="pv-chip" id="pv-pieces">الطلب: 5 ق</span>
                </div>
              </div>
            </div>

            <div class="pv-rows">
              <div class="pv-row" id="pv-sku-row"><span class="pv-lbl">SKU</span><span style="font-family:monospace;font-size:.58rem">LMS-1001-1</span></div>
              <div class="pv-row" id="pv-size-row"><span class="pv-lbl">المقاس</span><span>M</span></div>
              <div class="pv-row" id="pv-color-row"><span class="pv-lbl">اللون</span><span>أبيض</span></div>
              <div class="pv-row" id="pv-qty-row"><span class="pv-lbl">الكمية</span><span><strong>3</strong> قطعة</span></div>
              <div class="pv-row" id="pv-total-row"><span class="pv-lbl">الإجمالي</span><span><strong>5</strong> قطعة</span></div>
            </div>

            <div class="pv-qr" id="pv-qr">
              <div class="pv-qr-box">▦</div>
            </div>

            <div id="pv-barcode-text" style="text-align:center;font-family:monospace;font-size:.5rem;color:#888;padding-bottom:3px">LMS-1001-1</div>

            <div class="pv-notes" id="pv-notes">🧵 تطريز: اسم · 📝 ملاحظة</div>

            <div class="pv-check" id="pv-checklist">
              <div><span></span> استلام القماش</div>
              <div><span></span> القص والتجميع</div>
              <div><span></span> مراجعة الجودة</div>
            </div>

          </div>
          <div class="preview-info">
            معاينة تقريبية · الطباعة الفعلية قد تختلف قليلاً
          </div>
        </div>
      </div>

      <!-- Print shortcut -->
      <div style="margin-top:14px;text-align:center">
        <a href="/prep/print-all" target="_blank"
          style="display:inline-flex;align-items:center;gap:6px;background:#1a2d4a;color:#fff;border-radius:10px;padding:10px 20px;font-size:.85rem;font-weight:700;text-decoration:none">
          🖨️ معاينة الطباعة الكاملة
        </a>
      </div>
    </div>

  </div>
  </form>
</div>

<script>
// Map each field to the preview element(s) it controls
const FIELD_MAP = {
  show_image:            ['pv-img'],
  show_order_number:     ['pv-order-num'],
  show_product_name:     ['pv-name'],
  show_sku:              ['pv-sku-row'],
  show_size:             ['pv-size','pv-size-row'],
  show_color:            ['pv-color','pv-color-row'],
  show_quantity:         ['pv-qty','pv-qty-row'],
  show_pieces_count:     ['pv-pieces','pv-total-row'],
  show_type_badge:       ['pv-type-badge'],
  show_stage:            ['pv-stage'],
  show_qr:               ['pv-qr'],
  show_barcode_text:     ['pv-barcode-text'],
  show_embroidery:       ['pv-notes'],
  show_production_notes: ['pv-notes'],
  show_checklist:        ['pv-checklist'],
};

function updatePreview() {
  document.querySelectorAll('input[data-field]').forEach(function(cb) {
    const ids = FIELD_MAP[cb.dataset.field] || [];
    ids.forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.style.display = cb.checked ? '' : 'none';
    });
  });
}

function resetAll() {
  if (!confirm('إعادة جميع الإعدادات للحالة الافتراضية؟')) return;
  document.querySelectorAll('input[data-field]').forEach(cb => { cb.checked = true; });
  updatePreview();
}

// Init preview state on load
updatePreview();
</script>

<%- include('../partials/foot') %>
