<%# ════ CHART.JS ════ %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.font.family = "'Tajawal', sans-serif";
Chart.defaults.color = '#666';
Chart.defaults.borderColor = '#f0f0f0';

const dailyData   = <%- chartDaily %>;
const weeklyData  = <%- chartWeekly %>;
const monthlyData = <%- chartMonthly %>;

let chart = null;

function buildChart(data) {
  const ctx = document.getElementById('ordersChart').getContext('2d');
  if (chart) chart.destroy();
  const hasDone = data.some(d => (d.done || 0) > 0);
  const datasets = [
    {
      label: 'طلبات جديدة',
      data: data.map(d => d.count),
      backgroundColor: 'rgba(201,162,75,0.75)',
      borderRadius: 5,
      borderSkipped: false,
    }
  ];
  if (hasDone) {
    datasets.push({
      label: 'مكتملة',
      data: data.map(d => d.done || 0),
      backgroundColor: 'rgba(25,135,84,0.7)',
      borderRadius: 5,
      borderSkipped: false,
    });
  }
  chart = new Chart(ctx, {
    type: 'bar',
    data: { labels: data.map(d => d.label), datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'top', align: 'end', rtl: true, labels: { boxWidth: 12, padding: 12, font: { size: 12 } } }
      },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1, precision: 0 }, grid: { color: '#f4f4f4' } },
        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
      }
    }
  });
}

function showChart(period, btn) {
  document.querySelectorAll('.btn-group .btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  if      (period === 'daily')   buildChart(dailyData);
  else if (period === 'weekly')  buildChart(weeklyData);
  else                           buildChart(monthlyData);
}

buildChart(dailyData);

// Live clock
function updateClock() {
  const el = document.getElementById('dash-datetime');
  if (!el) return;
  const now = new Date();
  el.textContent = now.toLocaleDateString('ar-SA-u-nu-latn', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
  }) + '  ' + now.toLocaleTimeString('ar-SA-u-nu-latn', { hour: '2-digit', minute: '2-digit' });
}
updateClock();
setInterval(updateClock, 30000);

// Auto-refresh page every 5 minutes to keep data live
setTimeout(() => location.reload(), 5 * 60 * 1000);
</script>

