<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>طباعة بطاقات المنتج</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap">
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<style>
  *{font-family:'Tajawal',sans-serif; box-sizing:border-box}
  body{margin:20px}
  .card{border:2px dashed #999; border-radius:10px; padding:12px; width:280px; display:inline-block; margin:8px; vertical-align:top; page-break-inside:avoid}
  .card h6{margin:0 0 6px; font-weight:900}
  .row2{display:flex; justify-content:space-between; font-size:.85rem; margin-bottom:3px}
  .lbl{color:#777}
  svg{width:100%; margin-top:6px}
  .toolbar{margin-bottom:16px}
  @media print{ .toolbar{display:none} }
</style>
</head>
<body>
<div class="toolbar">
  <button onclick="window.print()">🖨️ طباعة</button>
</div>
<% orders.forEach(function(o){ %>
  <% o.items.forEach(function(it){ %>
  <div class="card">
    <h6><%= it.product_name %></h6>
    <div class="row2"><span class="lbl">رقم الطلب</span><span><%= o.order_number %></span></div>
    <div class="row2"><span class="lbl">المقاس</span><span><%= it.size || '—' %></span></div>
    <div class="row2"><span class="lbl">اللون</span><span><%= it.color || '—' %></span></div>
    <div class="row2"><span class="lbl">الكمية</span><span><%= it.qty %></span></div>
    <% if (it.embroidery_name) { %><div class="row2"><span class="lbl">اسم التطريز</span><span><%= it.embroidery_name %></span></div><% } %>
    <% if (it.notes) { %><div class="row2"><span class="lbl">ملاحظات</span><span><%= it.notes %></span></div><% } %>
    <svg class="bc" data-code="<%= it.barcode %>"></svg>
  </div>
  <% }) %>
<% }) %>

<script>
document.querySelectorAll('.bc').forEach(function(el){
  JsBarcode(el, el.getAttribute('data-code'), { fontSize: 14, height: 40, margin: 4 });
});
</script>
</body>
</html>
