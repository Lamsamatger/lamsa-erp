<%- include('partials/head', {title: 'الحسابات'}) %>
<h4 class="page-title">الحسابات</h4>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3"><div class="card-stat"><div class="num" style="font-size:1.4rem"><%= totalMaterials.toFixed(0) %></div><div class="lbl">المواد الخام</div></div></div>
  <div class="col-6 col-md-3"><div class="card-stat"><div class="num" style="font-size:1.4rem"><%= totalExpenses.toFixed(0) %></div><div class="lbl">المصروفات</div></div></div>
  <div class="col-6 col-md-3"><div class="card-stat"><div class="num" style="font-size:1.4rem"><%= totalWorkshopPaid.toFixed(0) %></div><div class="lbl">مدفوعات المشاغل</div></div></div>
  <div class="col-6 col-md-3"><div class="card-stat"><div class="num" style="font-size:1.4rem"><%= totalEmbroideryPaid.toFixed(0) %></div><div class="lbl">مدفوعات التطريز</div></div></div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="bg-white rounded p-3 shadow-sm mb-3">
      <h6>إضافة مادة خام / مشتريات</h6>
      <form method="POST" action="/accounts/material" class="row g-2">
        <div class="col-6"><input class="form-control" name="name" placeholder="اسم المادة" required></div>
        <div class="col-6">
          <select class="form-select" name="type">
            <option>قماش</option><option>خيوط</option><option>تطريز</option><option>تغليف</option>
          </select>
        </div>
        <div class="col-6"><input class="form-control" type="number" step="0.01" name="qty" placeholder="الكمية"></div>
        <div class="col-6"><input class="form-control" type="number" step="0.01" name="cost" placeholder="التكلفة" required></div>
        <div class="col-12"><button class="btn btn-brand w-100">إضافة</button></div>
      </form>
    </div>
    <div class="bg-white rounded p-3 shadow-sm">
      <h6>سجل المواد الخام</h6>
      <table class="table table-sm">
        <thead><tr><th>الاسم</th><th>النوع</th><th>الكمية</th><th>التكلفة</th><th>التاريخ</th></tr></thead>
        <tbody>
        <% materials.forEach(function(m){ %>
          <tr><td><%= m.name %></td><td><%= m.type %></td><td><%= m.qty %></td><td><%= m.cost.toFixed(2) %></td><td><%= new Date(m.date).toLocaleDateString('ar-SA') %></td></tr>
        <% }) %>
        <% if (!materials.length) { %><tr><td colspan="5" class="text-center text-muted">لا يوجد سجل</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="col-md-6">
    <div class="bg-white rounded p-3 shadow-sm mb-3">
      <h6>إضافة مصروف</h6>
      <form method="POST" action="/accounts/expense" class="row g-2">
        <div class="col-6"><input class="form-control" name="title" placeholder="بند المصروف" required></div>
        <div class="col-6"><input class="form-control" type="number" step="0.01" name="amount" placeholder="المبلغ" required></div>
        <div class="col-12"><input class="form-control" name="notes" placeholder="ملاحظات"></div>
        <div class="col-12"><button class="btn btn-brand w-100">إضافة</button></div>
      </form>
    </div>
    <div class="bg-white rounded p-3 shadow-sm">
      <h6>سجل المصروفات</h6>
      <table class="table table-sm">
        <thead><tr><th>البند</th><th>المبلغ</th><th>التاريخ</th></tr></thead>
        <tbody>
        <% expenses.forEach(function(ex){ %>
          <tr><td><%= ex.title %></td><td><%= ex.amount.toFixed(2) %></td><td><%= new Date(ex.date).toLocaleDateString('ar-SA') %></td></tr>
        <% }) %>
        <% if (!expenses.length) { %><tr><td colspan="3" class="text-center text-muted">لا يوجد سجل</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
