<%- include('../partials/head', {title: 'الأدوار والصلاحيات'}) %>

<style>
:root { --navy:#1a2d4a; --gold:#c9a24b; --green:#10b981; --red:#ef4444; --orange:#f59e0b; --purple:#8b5cf6; }

.roles-panel { background:#fff; border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.06); margin-bottom:20px; overflow:hidden; }
.roles-panel-hd { padding:14px 18px; border-bottom:1px solid #f0f0f0; font-weight:800; font-size:.9rem; color:var(--navy); }

/* Permission matrix */
.perm-matrix { width:100%; border-collapse:collapse; font-size:.82rem; }
.perm-matrix th { background:#1a2d4a; color:#fff; padding:10px 12px; font-size:.75rem; font-weight:700; text-align:center; border:1px solid #2d4a6e; white-space:nowrap; }
.perm-matrix th.row-hd { background:#f8fafc; color:var(--navy); text-align:right; }
.perm-matrix td { padding:9px 12px; border:1px solid #f0f0f0; text-align:center; vertical-align:middle; }
.perm-matrix td.row-hd { text-align:right; background:#fafbfc; font-weight:600; color:#444; font-size:.8rem; }
.perm-matrix tr:hover td { background:#f8fafc; }
.perm-matrix tr:hover td.row-hd { background:#f0f4f8; }

.check-ok { color:var(--green); font-size:1.1rem; font-weight:900; }
.check-no { color:#d1d5db; font-size:1.1rem; }
.check-hide { color:var(--orange); font-size:.9rem; font-weight:700; }

/* Section access grid */
.section-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:10px; padding:16px 18px; }
.section-row { background:#f8fafc; border-radius:10px; padding:10px 14px; }
.section-name { font-size:.82rem; font-weight:700; color:var(--navy); margin-bottom:6px; }
.role-pills { display:flex; flex-wrap:wrap; gap:4px; }
.role-pill { padding:2px 8px; border-radius:12px; font-size:.7rem; font-weight:700; background:var(--navy); color:#fff; }

/* Role cards summary -->
.role-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; padding:16px 18px; }
.role-card { background:#f8fafc; border-radius:12px; padding:14px 16px; border-right:4px solid var(--navy); }
.rc-name { font-size:.88rem; font-weight:800; color:var(--navy); margin-bottom:6px; }
.rc-id   { font-size:.72rem; color:#aaa; font-family:monospace; }
.rc-perms { display:flex; flex-wrap:wrap; gap:3px; margin-top:8px; }
.rcp { padding:2px 7px; border-radius:10px; font-size:.68rem; font-weight:700; }
.rcp-yes { background:#d1fae5; color:#065f46; }
.rcp-hide { background:#fef3c7; color:#92400e; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h1 class="page-title mb-0">🔐 الأدوار والصلاحيات</h1>
  <a href="/settings" class="btn btn-outline-secondary btn-sm">← الإعدادات</a>
</div>

<!-- Role cards overview -->
<div class="roles-panel">
  <div class="roles-panel-hd">👥 الأدوار المُعرَّفة في النظام</div>
  <div class="role-cards">
    <% var permLabels = { view:'عرض', add:'إضافة', edit:'تعديل', delete:'حذف', changeStatus:'الحالة', reports:'تقارير', manageInventory:'مخزون', manageUsers:'مستخدمين' }; %>
    <% Object.entries(ROLES).forEach(function([k,v]){ %>
    <% var p = ROLE_PERMISSIONS[k] || {}; %>
    <div class="role-card">
      <div class="rc-name"><%= v %></div>
      <div class="rc-id"><%= k %></div>
      <div class="rc-perms">
        <% Object.entries(permLabels).forEach(function([pk,pl]){ %>
        <% if (p[pk]) { %><span class="rcp rcp-yes"><%= pl %></span><% } %>
        <% }); %>
        <% if (p.hideCustomer) { %><span class="rcp rcp-hide">يُخفي العميل</span><% } %>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Full permission matrix -->
<div class="roles-panel">
  <div class="roles-panel-hd">📊 مصفوفة الصلاحيات الكاملة</div>
  <div class="table-responsive" style="padding:0">
    <table class="perm-matrix">
      <thead>
        <tr>
          <th class="row-hd" style="min-width:140px">الصلاحية</th>
          <% Object.entries(ROLES).forEach(function([k,v]){ %>
          <th style="min-width:90px"><span style="writing-mode:unset;font-size:.7rem"><%= v.replace('موظف ','').replace('مدير ','') %></span></th>
          <% }); %>
        </tr>
      </thead>
      <tbody>
        <% var PERM_ROWS = [
          { key:'view',            label:'👁️ عرض البيانات' },
          { key:'add',             label:'➕ إضافة بيانات' },
          { key:'edit',            label:'✏️ تعديل بيانات' },
          { key:'delete',          label:'🗑️ حذف بيانات' },
          { key:'changeStatus',    label:'🔁 تغيير حالة الطلبات' },
          { key:'reports',         label:'📈 الوصول للتقارير' },
          { key:'manageInventory', label:'🏭 إدارة المخزون' },
          { key:'manageUsers',     label:'👤 إدارة المستخدمين' },
          { key:'hideCustomer',    label:'🔒 يُخفى عنه بيانات العميل' }
        ]; %>
        <% PERM_ROWS.forEach(function(row){ %>
        <tr>
          <td class="row-hd"><%= row.label %></td>
          <% Object.keys(ROLES).forEach(function(rk){ %>
          <% var hasIt = (ROLE_PERMISSIONS[rk] || {})[row.key]; %>
          <td>
            <% if (row.key === 'hideCustomer') { %>
            <span class="<%=hasIt?'check-hide':'check-no'%>"><%=hasIt?'🔒':'—'%></span>
            <% } else { %>
            <span class="<%=hasIt?'check-ok':'check-no'%>"><%=hasIt?'✓':'✗'%></span>
            <% } %>
          </td>
          <% }); %>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Section access -->
<div class="roles-panel">
  <div class="roles-panel-hd">🗂️ الوصول لأقسام النظام</div>
  <div class="section-grid">
    <% var sectionLabels = {
      dashboard:'لوحة التحكم', orders:'الطلبات', products:'المنتجات',
      workshops:'المشاغل', embroiderers:'المطرزين', barcode:'الباركود',
      scanner:'ماسح الباركود', production:'الإنتاج', packaging:'التغليف والشحن',
      inventory:'المخزون', prep:'التجهيز', accounts:'الحسابات',
      users:'إدارة المستخدمين', settings:'الإعدادات'
    }; %>
    <% Object.entries(PERMISSIONS).forEach(function([section, roles]){ %>
    <div class="section-row">
      <div class="section-name"><%= sectionLabels[section] || section %></div>
      <div class="role-pills">
        <% roles.forEach(function(r){ %>
        <span class="role-pill"><%= (ROLES[r]||r).replace('موظف ','') %></span>
        <% }); %>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<%- include('../partials/foot') %>
