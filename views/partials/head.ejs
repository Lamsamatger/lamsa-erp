<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' | لمسة أزيائي' : 'لمسة أزيائي للإنتاج' %></title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap">
<link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<% if (user) { %>
<div class="topbar d-flex align-items-center justify-content-between px-3">
  <button class="btn btn-sm btn-outline-light d-lg-none" type="button" onclick="document.querySelector('.sidebar').classList.toggle('show')">☰</button>
  <div class="brand">لمسة أزيائي <span class="opacity-75">للإنتاج</span></div>
  <div class="d-flex align-items-center gap-2">
    <span class="text-white-50 small"><%= user.name %> · <%= ROLES[user.role] %></span>
    <form action="/logout" method="POST" class="m-0">
      <button class="btn btn-sm btn-outline-light">خروج</button>
    </form>
  </div>
</div>
<div class="app-wrap">
  <nav class="sidebar">
    <a class="nav-link <%= path==='/'?'active':'' %>" href="/">📊 لوحة التحكم</a>
    <a class="nav-link <%= path.startsWith('/orders')?'active':'' %>" href="/orders">📦 الطلبات</a>
    <a class="nav-link <%= path.startsWith('/prep')?'active':'' %>" href="/prep">🗂️ قوائم التجهيز</a>
    <a class="nav-link <%= path.startsWith('/barcode')?'active':'' %>" href="/barcode">🔍 مسح الباركود</a>
    <a class="nav-link <%= path.startsWith('/products')?'active':'' %>" href="/products">👗 المنتجات</a>
    <a class="nav-link <%= path.startsWith('/workshops')?'active':'' %>" href="/workshops">🏭 المشاغل</a>
    <a class="nav-link <%= path.startsWith('/embroiderers')?'active':'' %>" href="/embroiderers">🧵 المطرزين</a>
    <a class="nav-link <%= path.startsWith('/accounts')?'active':'' %>" href="/accounts">💰 الحسابات</a>
    <a class="nav-link <%= path.startsWith('/reports')?'active':'' %>" href="/reports">📈 التقارير</a>
    <% if (user.role === 'admin') { %>
    <a class="nav-link <%= path.startsWith('/users')?'active':'' %>" href="/users">👤 المستخدمون</a>
    <% } %>
  </nav>
  <main class="content">
<% } else { %>
<main class="content-full">
<% } %>
