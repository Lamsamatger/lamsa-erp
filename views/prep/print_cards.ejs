<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بطاقات التجهيز | لمسة أزيائي</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap">
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<style>
<%
  const cs = cardSettings || {};
  const marginMm = Math.max(0, Math.min(10, Number(cs.margin_mm) || 2));
  const qrPx = cs.qr_size === 'large' ? 96 : cs.qr_size === 'small' ? 56 : 76;
%>
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
body { font-family:'Tajawal',sans-serif; background:#f0f2f5; direction:rtl; }

/* ── Toolbar ── */
.toolbar {
  background:#1a2d4a; padding:10px 20px;
  display:flex; align-items:center; gap:10px; flex-wrap:wrap;
  position:sticky; top:0; z-index:100; box-shadow:0 2px 8px rgba(0,0,0,.3);
}
.toolbar .brand { color:#c9a24b; font-weight:900; font-size:1rem; }
.toolbar .stat  { color:#fff; font-size:.85rem; background:rgba(255,255,255,.1); padding:4px 10px; border-radius:6px; }
.toolbar .btn-print {
  background:#c9a24b; color:#fff; border:none; border-radius:8px;
  padding:8px 20px; font-size:.9rem; font-family:'Tajawal',sans-serif;
  font-weight:700; cursor:pointer; transition:background .15s;
}
.toolbar .btn-print:hover { background:#b8902f; }
.toolbar .btn-back {
  background:transparent; color:rgba(255,255,255,.8); border:1px solid rgba(255,255,255,.3);
  border-radius:8px; padding:6px 14px; font-size:.82rem; font-family:'Tajawal',sans-serif;
  cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:4px;
}
.toolbar .btn-back:hover { background:rgba(255,255,255,.1); color:#fff; }
.layout-btns { display:flex; gap:4px; margin-right:auto; }
.layout-btns button {
  background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);
  border-radius:6px; padding:5px 14px; font-size:.8rem; font-family:'Tajawal',sans-serif; cursor:pointer;
}
.layout-btns button.active { background:#c9a24b; border-color:#c9a24b; font-weight:700; }

.screen-preview { padding:20px; }
.print-page-wrap {
  background:#fff; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,.1);
  margin:0 auto 24px; padding:10px; max-width:880px;
}
.print-page-label { text-align:center; font-size:.72rem; color:#aaa; font-weight:600; margin-bottom:8px; }

.print-grid { display:grid; gap:<%= marginMm %>mm; }
.layout-12 .print-grid { grid-template-columns:repeat(3,1fr); }
.layout-16 .print-grid { grid-template-columns:repeat(4,1fr); }

/* ── Single prep card ── */
.prep-card {
  border:1.5px solid #ccc; border-radius:8px; overflow:hidden;
  background:#fff; display:flex; flex-direction:column; font-size:.78rem;
}
.pc-header {
  background:#1a2d4a; color:#fff; padding:5px 8px;
  display:flex; justify-content:space-between; align-items:center; gap:4px; flex-shrink:0;
}
.pc-order { font-family:monospace; font-weight:700; font-size:.82rem; }
.pc-badges { display:flex; gap:3px; align-items:center; flex-wrap:wrap; }
.pc-badge { font-size:.58rem; padding:1px 5px; border-radius:10px; font-weight:700; white-space:nowrap; }
.pc-badge.type-prod  { background:#0d6efd; color:#fff; }
.pc-badge.type-stock { background:#198754; color:#fff; }
.pc-badge.status     { background:rgba(255,255,255,.18); color:#fff; }

.pc-stage-strip {
  background:#f0f4ff; border-bottom:1px solid #e0e8f5;
  padding:3px 8px; font-size:.65rem; font-weight:700; color:#1a2d4a;
  display:flex; align-items:center; gap:4px; flex-shrink:0;
}
.pc-stage-dot { width:7px; height:7px; border-radius:50%; background:#c9a24b; flex-shrink:0; }

.pc-body { display:flex; gap:6px; padding:6px; align-items:flex-start; flex-shrink:0; }
.pc-img {
  width:52px; height:52px; flex-shrink:0; border-radius:5px;
  background:#f4f6f9; border:1px solid #eee; overflow:hidden;
  display:flex; align-items:center; justify-content:center; font-size:1.6rem;
}
.pc-img img { width:100%; height:100%; object-fit:cover; }
.pc-info { flex:1; min-width:0; }
.pc-name {
  font-weight:700; font-size:.8rem; color:#1a2d4a; line-height:1.3; margin-bottom:3px;
  overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;
}
.pc-chips { display:flex; flex-wrap:wrap; gap:2px; }
.pc-chip { background:#f0f4ff; color:#2d5096; border-radius:4px; padding:0 5px; font-size:.65rem; font-weight:600; line-height:1.6; }
.pc-chip.qty   { background:#e8f5e9; color:#1b5e20; }
.pc-chip.total { background:#fef3c7; color:#92400e; }

.pc-rows { padding:0 6px 4px; flex-shrink:0; }
.pc-row {
  display:flex; justify-content:space-between; align-items:center;
  font-size:.7rem; padding:1.5px 0; border-bottom:1px solid #f5f5f5;
}
.pc-row:last-child { border-bottom:none; }
.pc-lbl { color:#999; }
.pc-val { font-weight:600; color:#333; text-align:left; }

.pc-qr-zone { padding:6px 6px 2px; display:flex; flex-direction:column; align-items:center; gap:2px; flex-shrink:0; }
.pc-qr-wrap {
  background:#fff; border:1.5px solid #e0e0e0; border-radius:6px;
  padding:4px; display:inline-flex; align-items:center; justify-content:center;
}
.pc-qr-label { font-family:monospace; font-size:.52rem; color:#888; text-align:center; word-break:break-all; }

.pc-notes {
  margin:0 6px 4px; background:#fffbf0; border:1px dashed #e8c96a;
  border-radius:5px; padding:3px 6px; font-size:.67rem; color:#6b5000; flex-shrink:0;
}
.pc-checklist { margin-top:auto; border-top:1px dashed #e0e0e0; padding:4px 6px 5px; }
.pc-checklist .cl-item { display:flex; align-items:center; gap:4px; font-size:.64rem; color:#555; margin-bottom:2px; }
.pc-checklist .cl-box { width:11px; height:11px; border:1.5px solid #999; border-radius:2px; flex-shrink:0; background:#fff; }

/* ── PRINT ── */
@media print {
  *, *::before, *::after { -webkit-print-color-adjust:exact !important; print-color-adjust:exact !important; }
  @page { size:A4 portrait; margin:<%= marginMm %>mm; }
  body   { background:white; }
  .no-print { display:none !important; }
  .screen-preview { padding:0; }
  .print-page-label { display:none; }
  .print-page-wrap {
    background:transparent; box-shadow:none; border-radius:0; padding:0; margin:0; max-width:none;
    break-after:page; page-break-after:always;
  }
  .print-page-wrap:last-child { break-after:avoid; page-break-after:avoid; }
  .layout-12 .print-grid { display:grid; grid-template-columns:repeat(3,65mm); grid-template-rows:repeat(4,70mm); gap:<%= marginMm %>mm; width:200mm; }
  .layout-16 .print-grid { display:grid; grid-template-columns:repeat(4,48mm); grid-template-rows:repeat(4,70mm); gap:<%= marginMm %>mm; width:200mm; }
  .prep-card { border:0.5pt solid #888; border-radius:2mm; overflow:hidden; break-inside:avoid; }
  .layout-16 .pc-body  { padding:3px 4px; }
  .layout-16 .pc-img   { width:36px; height:36px; font-size:1.1rem; }
  .layout-16 .pc-name  { font-size:.7rem; }
  .layout-16 .pc-chip  { font-size:.56rem; }
  .layout-16 .pc-row   { font-size:.62rem; }
  .layout-16 .pc-notes { font-size:.58rem; padding:2px 4px; }
  .layout-16 .pc-checklist .cl-item { font-size:.58rem; margin-bottom:1px; }
  .layout-16 .pc-qr-zone { padding:4px 4px 2px; }
  .pc-header         { background:#1a2d4a !important; color:#fff !important; }
  .pc-stage-strip    { background:#f0f4ff !important; }
  .pc-badge.type-prod  { background:#0d6efd !important; }
  .pc-badge.type-stock { background:#198754 !important; }
  .pc-chip     { background:#eef2ff !important; color:#2d5096 !important; }
  .pc-chip.qty { background:#e8f5e9 !important; color:#1b5e20 !important; }
  .pc-chip.total { background:#fef3c7 !important; color:#92400e !important; }
}
</style>
</head>
<body>

<%
  const cs2 = cardSettings || {};
  let totalCards = 0;
  orders.forEach(o => { totalCards += o.items.length; });
  const cpp  = parseInt(cardsPerPage) === 16 ? 16 : 12;
  const allCards = [];
  orders.forEach(function(order) { order.items.forEach(function(item) { allCards.push({ order, item }); }); });
  const pages = [];
  for (let i = 0; i < allCards.length; i += cpp) pages.push(allCards.slice(i, i + cpp));
%>

<div class="toolbar no-print">
  <a href="/prep" class="btn-back">← العودة</a>
  <span class="brand">🗂️ بطاقات التجهيز</span>
  <span class="stat"><%= totalCards %> بطاقة · <%= pages.length %> صفحة</span>
  <div class="layout-btns">
    <button onclick="setLayout(12)" class="<%= cpp===12?'active':'' %>">⊞ 12 بطاقة</button>
    <button onclick="setLayout(16)" class="<%= cpp===16?'active':'' %>">⊟ 16 بطاقة</button>
  </div>
  <button class="btn-print" onclick="window.print()">🖨️ طباعة A4</button>
</div>

<% if (!orders.length) { %>
  <div style="text-align:center;padding:60px 20px;color:#888">
    <p>لم يتم تحديد أي طلبات.</p>
    <a href="/prep" class="btn-back" style="font-size:.9rem">← العودة لقائمة التجهيز</a>
  </div>
<% } else { %>

<div class="screen-preview layout-<%= cpp %>" id="main-wrap">
<% pages.forEach(function(page, pi) { %>
  <div class="print-page-wrap">
    <div class="print-page-label no-print">صفحة <%= pi+1 %> من <%= pages.length %></div>
    <div class="print-grid">
    <% page.forEach(function(c) {
      const order = c.order;
      const item  = c.item;
      const isStock = (order.order_type || 'إنتاج') === 'مخزون';
      const orderTotalPieces = order.totalPieces || order.items.reduce((s,i)=>s+(Math.max(0,Number(i.qty)||0)),0);
      const qrUrl = baseUrl + '/scanner/item/' + encodeURIComponent(item.barcode);
    %>
    <div class="prep-card">

      <!-- Header -->
      <div class="pc-header">
        <% if (cs2.show_order_number !== false) { %>
        <span class="pc-order"><%= order.order_number %></span>
        <% } %>
        <div class="pc-badges">
          <% if (cs2.show_type_badge !== false) { %>
          <span class="pc-badge <%= isStock ? 'type-stock' : 'type-prod' %>"><%= isStock ? 'مخزون' : 'إنتاج' %></span>
          <% } %>
          <span class="pc-badge status"><%= order.status %></span>
        </div>
      </div>

      <!-- Stage strip -->
      <% if (cs2.show_stage !== false) { %>
      <div class="pc-stage-strip">
        <span class="pc-stage-dot"></span>
        المرحلة: <%= item.stage || 'تجهيز' %>
      </div>
      <% } %>

      <!-- Body -->
      <div class="pc-body">
        <% if (cs2.show_image !== false) { %>
        <div class="pc-img">
          <% if (item.image_url && /^https?:\/\//i.test(item.image_url)) { %>
            <img src="<%= item.image_url %>" alt="<%= item.product_name %>" onerror="this.parentNode.innerHTML='👗'">
          <% } else { %>👗<% } %>
        </div>
        <% } %>
        <div class="pc-info">
          <% if (cs2.show_product_name !== false) { %>
          <div class="pc-name"><%= item.product_name %></div>
          <% } %>
          <div class="pc-chips">
            <% if (cs2.show_size !== false && item.size)  { %><span class="pc-chip">📐 <%= item.size %></span><% } %>
            <% if (cs2.show_color !== false && item.color) { %><span class="pc-chip">🎨 <%= item.color %></span><% } %>
            <% if (cs2.show_quantity !== false) { %><span class="pc-chip qty">الكمية: <%= item.qty %></span><% } %>
            <% if (cs2.show_pieces_count !== false) { %><span class="pc-chip total">الطلب: <%= orderTotalPieces %> ق</span><% } %>
          </div>
        </div>
      </div>

      <!-- Detail rows -->
      <div class="pc-rows">
        <% if (cs2.show_sku !== false) { %>
        <div class="pc-row">
          <span class="pc-lbl">SKU</span>
          <span class="pc-val" dir="ltr" style="font-family:monospace;font-size:.6rem"><%= item.barcode %></span>
        </div>
        <% } %>
        <% if (cs2.show_size !== false && item.size) { %>
        <div class="pc-row"><span class="pc-lbl">المقاس</span><span class="pc-val"><%= item.size %></span></div>
        <% } %>
        <% if (cs2.show_color !== false && item.color) { %>
        <div class="pc-row"><span class="pc-lbl">اللون</span><span class="pc-val"><%= item.color %></span></div>
        <% } %>
        <% if (cs2.show_quantity !== false) { %>
        <div class="pc-row"><span class="pc-lbl">الكمية</span><span class="pc-val"><strong><%= item.qty %></strong> قطعة</span></div>
        <% } %>
        <% if (cs2.show_pieces_count !== false) { %>
        <div class="pc-row"><span class="pc-lbl">إجمالي الطلب</span><span class="pc-val"><strong><%= orderTotalPieces %></strong> قطعة</span></div>
        <% } %>
      </div>

      <!-- QR -->
      <% if (cs2.show_qr !== false) { %>
      <div class="pc-qr-zone">
        <div class="pc-qr-wrap">
          <canvas class="qr-canvas" data-url="<%= qrUrl %>"></canvas>
        </div>
        <% if (cs2.show_barcode_text !== false) { %>
        <div class="pc-qr-label"><%= item.barcode %></div>
        <% } %>
      </div>
      <% } %>

      <!-- Embroidery / notes -->
      <% if ((cs2.show_embroidery !== false && item.embroidery_name) || (cs2.show_production_notes !== false && item.notes)) { %>
      <div class="pc-notes">
        <% if (cs2.show_embroidery !== false && item.embroidery_name) { %>🧵 <%= item.embroidery_name %><br><% } %>
        <% if (cs2.show_production_notes !== false && item.notes) { %>📝 <%= item.notes %><% } %>
      </div>
      <% } %>

      <!-- Checklist -->
      <% if (cs2.show_checklist !== false) { %>
      <div class="pc-checklist">
        <div class="cl-item"><span class="cl-box"></span> استلام القماش والخامة</div>
        <div class="cl-item"><span class="cl-box"></span> القص والتحضير</div>
        <div class="cl-item"><span class="cl-box"></span> الخياطة والتجميع</div>
        <% if (item.embroidery_name) { %>
        <div class="cl-item"><span class="cl-box"></span> التطريز ✓</div>
        <% } %>
        <div class="cl-item"><span class="cl-box"></span> مراجعة الجودة</div>
        <div class="cl-item"><span class="cl-box"></span> جاهز للتسليم ✓</div>
      </div>
      <% } %>

    </div>
    <% }) %>
    </div>
  </div>
<% }) %>
</div>
<% } %>

<script>
const QR_SIZE = <%= qrPx %>;
document.querySelectorAll('canvas.qr-canvas').forEach(function(canvas) {
  const url = canvas.getAttribute('data-url');
  QRCode.toCanvas(canvas, url, { width: QR_SIZE, margin:1, errorCorrectionLevel:'M' }, function(){});
});
function setLayout(n) {
  const url = new URL(window.location.href);
  url.searchParams.set('layout', n);
  window.location.href = url.toString();
}
if (new URLSearchParams(window.location.search).get('autoprint') === '1') {
  setTimeout(() => window.print(), 1200);
}
</script>
</body>
</html>
