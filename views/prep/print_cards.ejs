<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بطاقات التجهيز | لمسة أزيائي</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
<link rel="stylesheet" href="/public/css/style.css">
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<style>
  body { font-family: 'Tajawal', sans-serif; background: #f4f6f9; }
  .toolbar { background: #1a2d4a; padding: 12px 20px; display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
  .toolbar .btn { min-height: 40px; }
  .toolbar span { color: #fff; font-weight: 700; font-size: 1rem; }

  /* Screen card styles */
  .cards-grid { padding: 16px; }
  .prep-card { font-size: .82rem; }
  .prep-card-header { font-size: .85rem; font-weight: 700; }
  .prep-card p { margin-bottom: 2px; }
  .detail-row { display: flex; justify-content: space-between; font-size: .78rem; padding: 1px 0; border-bottom: 1px solid #f0f0f0; }
  .detail-row:last-child { border-bottom: none; }
  .detail-row .lbl { color: #888; }

  /* Summary badge */
  .card-count-badge { background: #1a2d4a; color: #fff; border-radius: 6px; padding: 2px 8px; font-size: .75rem; }
</style>
</head>
<body>

<div class="toolbar no-print">
  <a href="/prep" class="btn btn-outline-light btn-sm">← العودة</a>
  <span>بطاقات التجهيز</span>
  <span class="card-count-badge ms-2">
    <% let totalCards = 0; orders.forEach(o => { totalCards += o.items.length; }); %>
    <%= totalCards %> بطاقة
  </span>
  <div class="ms-auto d-flex gap-2">
    <button onclick="window.print()" class="btn btn-brand">🖨️ طباعة (A4 · 12 بطاقة/صفحة)</button>
  </div>
</div>

<% if (!orders.length) { %>
  <div class="text-center py-5 no-print">
    <p class="text-muted fs-5">لم يتم تحديد أي طلبات للطباعة.</p>
    <a href="/prep" class="btn btn-brand">العودة لقائمة التجهيز</a>
  </div>
<% } else { %>

<div class="cards-grid">
  <div class="row g-3" id="cards-container">
  <%
    let cardIndex = 0;
    orders.forEach(function(order) {
      order.items.forEach(function(item) {
        cardIndex++;
        const statusColors = {
          'جديد': '#6c757d', 'مراجعة': '#0dcaf0', 'تجهيز': '#0d6efd',
          'عند المشغل': '#ffc107', 'مستلم من المشغل': '#ffc107',
          'عند المطرز': '#7c3aed', 'جاهز للتغليف': '#198754',
          'تم التنفيذ': '#212529', 'ملغي': '#dc3545'
        };
        const statusColor = statusColors[order.status] || '#6c757d';
  %>
  <div class="col-md-4 col-6">
    <div class="prep-card" data-barcode="<%= item.barcode %>">
      <!-- Header -->
      <div class="prep-card-header">
        <span><%= order.order_number %></span>
        <span style="font-size:.7rem; background:<%= statusColor %>; color:#fff; padding:1px 6px; border-radius:4px;"><%= order.status %></span>
      </div>

      <!-- Barcode -->
      <div class="prep-card-barcode">
        <svg class="bc" data-code="<%= item.barcode %>"></svg>
        <div style="font-size:.65rem; color:#666; margin-top:1px; font-family:monospace;"><%= item.barcode %></div>
      </div>

      <!-- Product details -->
      <div class="d-flex gap-2 mb-1">
        <% if (item.image_url) { %>
          <img src="<%= item.image_url %>" class="prep-card-img" alt="<%= item.product_name %>" onerror="this.style.display='none'">
        <% } %>
        <div class="flex-grow-1">
          <strong class="d-block" style="font-size:.82rem; line-height:1.2;"><%= item.product_name %></strong>
          <% if (item.embroidery_name) { %>
            <div style="font-size:.72rem; color:#7c3aed;">🧵 <%= item.embroidery_name %></div>
          <% } %>
        </div>
      </div>

      <div class="detail-row"><span class="lbl">المقاس</span><span><%= item.size || '—' %></span></div>
      <div class="detail-row"><span class="lbl">اللون</span><span><%= item.color || '—' %></span></div>
      <div class="detail-row"><span class="lbl">الكمية</span><strong><%= item.qty %></strong></div>
      <div class="detail-row"><span class="lbl">المرحلة</span><span><%= item.stage || '—' %></span></div>
      <% if (item.notes) { %>
      <div class="detail-row"><span class="lbl">ملاحظات</span><span style="font-size:.7rem;"><%= item.notes %></span></div>
      <% } %>

      <!-- Checklist -->
      <div class="prep-checklist">
        <label><input type="checkbox"> استلام القماش</label>
        <label><input type="checkbox"> القص والتحضير</label>
        <label><input type="checkbox"> الخياطة</label>
        <% if (item.embroidery_name) { %>
        <label><input type="checkbox"> التطريز</label>
        <% } %>
        <label><input type="checkbox"> مراجعة الجودة</label>
        <label><input type="checkbox"> جاهز للتسليم</label>
      </div>
    </div>
  </div>
  <%   }); // end items
     }); // end orders
  %>
  </div>
</div>

<% } %>

<script>
// Generate barcodes
document.querySelectorAll('svg.bc').forEach(function(el) {
  try {
    JsBarcode(el, el.getAttribute('data-code'), {
      format: 'CODE128',
      fontSize: 10,
      height: 36,
      margin: 2,
      displayValue: false
    });
  } catch(e) {}
});

// Auto-print after a short delay if ?autoprint=1
if (new URLSearchParams(window.location.search).get('autoprint') === '1') {
  setTimeout(() => window.print(), 800);
}
</script>
</body>
</html>
