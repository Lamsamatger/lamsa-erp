<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بطاقات التجهيز | لمسة أزيائي</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap">
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<style>
/* ── Base ── */
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
body { font-family:'Tajawal',sans-serif; background:#f0f2f5; direction:rtl; }

/* ── Toolbar ── */
.toolbar {
  background:#1a2d4a; padding:10px 20px;
  display:flex; align-items:center; gap:10px; flex-wrap:wrap;
  position:sticky; top:0; z-index:100; box-shadow:0 2px 8px rgba(0,0,0,.3);
}
.toolbar .brand { color:#c9a24b; font-weight:900; font-size:1rem; }
.toolbar .stat  { color:#fff; font-size:.85rem; background:rgba(255,255,255,.1); padding:4px 10px; border-radius:6px; }
.toolbar .btn-print {
  background:#c9a24b; color:#fff; border:none; border-radius:8px;
  padding:8px 20px; font-size:.9rem; font-family:'Tajawal',sans-serif;
  font-weight:700; cursor:pointer; transition:background .15s;
}
.toolbar .btn-print:hover { background:#b8902f; }
.toolbar .btn-back {
  background:transparent; color:rgba(255,255,255,.8); border:1px solid rgba(255,255,255,.3);
  border-radius:8px; padding:6px 14px; font-size:.82rem; font-family:'Tajawal',sans-serif;
  cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:4px;
  transition:all .15s;
}
.toolbar .btn-back:hover { background:rgba(255,255,255,.1); color:#fff; }
.layout-btns { display:flex; gap:4px; margin-right:auto; }
.layout-btns button {
  background:rgba(255,255,255,.1); color:#fff; border:1px solid rgba(255,255,255,.2);
  border-radius:6px; padding:5px 14px; font-size:.8rem; font-family:'Tajawal',sans-serif;
  cursor:pointer; transition:all .15s;
}
.layout-btns button.active { background:#c9a24b; border-color:#c9a24b; font-weight:700; }

/* ── Screen preview container ── */
.screen-preview { padding:20px; }

/* ── Page wrapper for screen ── */
.print-page-wrap {
  background:#fff; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,.1);
  margin:0 auto 24px; padding:10px;
  max-width:860px;
}
.print-page-label {
  text-align:center; font-size:.72rem; color:#aaa; font-weight:600;
  margin-bottom:8px; text-transform:uppercase; letter-spacing:.5px;
}

/* ── Cards grid (screen) ── */
.print-grid {
  display:grid;
  gap:6px;
}
.layout-12 .print-grid { grid-template-columns:repeat(3,1fr); }
.layout-16 .print-grid { grid-template-columns:repeat(4,1fr); }

/* ── Single prep card ── */
.prep-card {
  border:1.5px solid #ccc; border-radius:8px; overflow:hidden;
  background:#fff; display:flex; flex-direction:column;
  font-size:.78rem;
}

/* Card header */
.pc-header {
  background:#1a2d4a; color:#fff; padding:5px 8px;
  display:flex; justify-content:space-between; align-items:center; gap:4px;
  flex-shrink:0;
}
.pc-order { font-family:monospace; font-weight:700; font-size:.82rem; letter-spacing:.3px; }
.pc-status {
  font-size:.62rem; padding:1px 6px; border-radius:20px; font-weight:700;
  background:rgba(255,255,255,.15); color:#fff; white-space:nowrap;
}

/* Card body */
.pc-body { display:flex; gap:6px; padding:6px; align-items:flex-start; flex-shrink:0; }
.pc-img {
  width:48px; height:48px; flex-shrink:0; border-radius:5px;
  background:#f4f6f9; border:1px solid #eee; overflow:hidden;
  display:flex; align-items:center; justify-content:center; font-size:1.5rem;
}
.pc-img img { width:100%; height:100%; object-fit:cover; }
.pc-info { flex:1; min-width:0; }
.pc-name { font-weight:700; font-size:.8rem; color:#1a2d4a; line-height:1.3; margin-bottom:3px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
.pc-chips { display:flex; flex-wrap:wrap; gap:2px; }
.pc-chip {
  background:#f0f4ff; color:#2d5096; border-radius:4px;
  padding:0 5px; font-size:.65rem; font-weight:600; line-height:1.6;
}
.pc-chip.qty { background:#e8f5e9; color:#1b5e20; }

/* Details rows */
.pc-rows { padding:0 6px 4px; flex-shrink:0; }
.pc-row {
  display:flex; justify-content:space-between; align-items:center;
  font-size:.72rem; padding:1.5px 0; border-bottom:1px solid #f5f5f5;
}
.pc-row:last-child { border-bottom:none; }
.pc-lbl { color:#999; }
.pc-val { font-weight:600; color:#333; text-align:left; }

/* QR + Barcode zone */
.pc-code-zone {
  padding:4px 6px; display:flex; flex-direction:column; align-items:center;
  gap:2px; flex-shrink:0;
}
.pc-qr canvas, .pc-qr img { display:block; }
.pc-bc svg { max-width:100%; }
.pc-code-label { font-family:monospace; font-size:.55rem; color:#888; text-align:center; }

/* Notes */
.pc-notes {
  margin:0 6px 4px; background:#fffbf0; border:1px dashed #e8c96a;
  border-radius:5px; padding:3px 6px; font-size:.68rem; color:#6b5000; flex-shrink:0;
}

/* Checklist */
.pc-checklist { margin-top:auto; border-top:1px dashed #e0e0e0; padding:4px 6px 5px; }
.pc-checklist .cl-item {
  display:flex; align-items:center; gap:4px;
  font-size:.66rem; color:#555; margin-bottom:2px;
}
.pc-checklist .cl-box {
  width:11px; height:11px; border:1.5px solid #999; border-radius:2px;
  flex-shrink:0; background:#fff;
}

/* ── PRINT STYLES ── */
@media print {
  * { -webkit-print-color-adjust:exact !important; print-color-adjust:exact !important; }
  @page { size:A4 portrait; margin:5mm; }

  body   { background:white; }
  .no-print { display:none !important; }

  .screen-preview { padding:0; }
  .print-page-label { display:none; }

  .print-page-wrap {
    background:transparent; box-shadow:none; border-radius:0;
    padding:0; margin:0; max-width:none;
    /* page break between page groups */
    break-after:page; page-break-after:always;
  }
  .print-page-wrap:last-child { break-after:avoid; page-break-after:avoid; }

  /* ── 12 per page: 3 × 4 on A4 (print area 200mm × 287mm, gap 2mm) ── */
  .layout-12 .print-grid {
    display:grid;
    grid-template-columns:repeat(3, 65.3mm);
    grid-template-rows:repeat(4, 70mm);
    gap:2mm;
    width:200mm;
  }

  /* ── 16 per page: 4 × 4 on A4 ── */
  .layout-16 .print-grid {
    display:grid;
    grid-template-columns:repeat(4, 48mm);
    grid-template-rows:repeat(4, 70mm);
    gap:2mm;
    width:200mm;
  }

  .prep-card {
    border:0.5pt solid #888;
    border-radius:2mm;
    overflow:hidden;
    break-inside:avoid;
    page-break-inside:avoid;
  }

  /* In 16/page mode hide product image to save space */
  .layout-16 .pc-body { padding:4px 5px; }
  .layout-16 .pc-img { width:36px; height:36px; font-size:1.1rem; }
  .layout-16 .pc-name { font-size:.72rem; }
  .layout-16 .pc-chip { font-size:.58rem; }
  .layout-16 .pc-row  { font-size:.65rem; }
  .layout-16 .pc-notes { font-size:.6rem; padding:2px 4px; }
  .layout-16 .pc-checklist .cl-item { font-size:.58rem; margin-bottom:1px; }

  /* colours in print */
  .pc-header { background:#1a2d4a !important; color:#fff !important; }
  .pc-chip   { background:#eef2ff !important; color:#2d5096 !important; }
  .pc-chip.qty { background:#e8f5e9 !important; color:#1b5e20 !important; }
}
</style>
</head>
<body>

<%
  let totalCards = 0;
  orders.forEach(o => { totalCards += o.items.length; });
  const cpp = parseInt(cardsPerPage) === 16 ? 16 : 12;
  const cols = cpp === 16 ? 4 : 3;
  const rows = 4;

  // flatten all items into a single array
  const allCards = [];
  orders.forEach(function(order) {
    order.items.forEach(function(item) {
      allCards.push({ order, item });
    });
  });

  // chunk into pages
  const pages = [];
  for (let i = 0; i < allCards.length; i += cpp) {
    pages.push(allCards.slice(i, i + cpp));
  }
%>

<!-- Toolbar -->
<div class="toolbar no-print">
  <a href="/prep" class="btn-back">← العودة</a>
  <span class="brand">🗂️ بطاقات التجهيز</span>
  <span class="stat"><%= totalCards %> بطاقة · <%= pages.length %> صفحة</span>

  <div class="layout-btns">
    <button onclick="setLayout(12)" id="btn-12" class="<%= cpp===12?'active':'' %>">⊞ 12 بطاقة/صفحة</button>
    <button onclick="setLayout(16)" id="btn-16" class="<%= cpp===16?'active':'' %>">⊟ 16 بطاقة/صفحة</button>
  </div>

  <button class="btn-print" onclick="window.print()">
    🖨️ طباعة A4 · <%= cpp %> بطاقة/صفحة
  </button>
</div>

<% if (!orders.length) { %>
  <div style="text-align:center;padding:60px 20px;color:#888">
    <p style="font-size:1.1rem;margin-bottom:12px">لم يتم تحديد أي طلبات.</p>
    <a href="/prep" class="btn-back" style="font-size:.9rem;display:inline-flex;gap:6px;">← العودة لقائمة التجهيز</a>
  </div>
<% } else { %>

<div class="screen-preview layout-<%= cpp %>" id="main-wrap">
<% pages.forEach(function(page, pi) { %>
  <div class="print-page-wrap">
    <div class="print-page-label no-print">صفحة <%= pi+1 %> من <%= pages.length %></div>
    <div class="print-grid">
    <% page.forEach(function(c) {
      const order = c.order;
      const item  = c.item;
      const statusColors = {
        'جديد':'#64748b','مراجعة':'#0ea5e9','تجهيز':'#3b82f6',
        'عند المشغل':'#f59e0b','مستلم من المشغل':'#f97316',
        'عند المطرز':'#8b5cf6','جاهز للتغليف':'#10b981',
        'تم التنفيذ':'#1a2d4a','ملغي':'#ef4444'
      };
    %>
    <div class="prep-card">

      <!-- Header -->
      <div class="pc-header">
        <span class="pc-order"><%= order.order_number %></span>
        <span class="pc-status"><%= order.status %></span>
      </div>

      <!-- Body: image + info -->
      <div class="pc-body">
        <div class="pc-img">
          <% if (item.image_url && /^https?:\/\//i.test(item.image_url)) { %>
            <img src="<%= item.image_url %>" alt="<%= item.product_name %>"
              onerror="this.parentNode.innerHTML='👗'">
          <% } else { %>👗<% } %>
        </div>
        <div class="pc-info">
          <div class="pc-name"><%= item.product_name %></div>
          <div class="pc-chips">
            <% if (item.size)  { %><span class="pc-chip">📐 <%= item.size %></span><% } %>
            <% if (item.color) { %><span class="pc-chip">🎨 <%= item.color %></span><% } %>
            <span class="pc-chip qty">× <%= item.qty %></span>
          </div>
        </div>
      </div>

      <!-- Detail rows -->
      <div class="pc-rows">
        <div class="pc-row"><span class="pc-lbl">الباركود</span><span class="pc-val" dir="ltr" style="font-family:monospace;font-size:.62rem"><%= item.barcode %></span></div>
        <div class="pc-row"><span class="pc-lbl">المرحلة</span><span class="pc-val"><%= item.stage||'تجهيز' %></span></div>
        <div class="pc-row"><span class="pc-lbl">المقاس</span><span class="pc-val"><%= item.size||'—' %></span></div>
        <div class="pc-row"><span class="pc-lbl">اللون</span><span class="pc-val"><%= item.color||'—' %></span></div>
        <div class="pc-row"><span class="pc-lbl">الكمية</span><span class="pc-val"><strong><%= item.qty %></strong></span></div>
      </div>

      <!-- QR code (canvas) -->
      <div class="pc-code-zone">
        <div class="pc-qr">
          <canvas class="qr-canvas" data-code="<%= item.barcode %>"></canvas>
        </div>
        <div class="pc-code-label"><%= item.barcode %></div>
      </div>

      <!-- Notes -->
      <% if (item.notes || item.embroidery_name) { %>
      <div class="pc-notes">
        <% if (item.embroidery_name) { %>🧵 <%= item.embroidery_name %><br><% } %>
        <% if (item.notes) { %>📝 <%= item.notes %><% } %>
      </div>
      <% } %>

      <!-- Checklist -->
      <div class="pc-checklist">
        <div class="cl-item"><span class="cl-box"></span> استلام القماش والخامة</div>
        <div class="cl-item"><span class="cl-box"></span> القص والتحضير</div>
        <div class="cl-item"><span class="cl-box"></span> الخياطة والتجميع</div>
        <% if (item.embroidery_name) { %>
        <div class="cl-item"><span class="cl-box"></span> التطريز</div>
        <% } %>
        <div class="cl-item"><span class="cl-box"></span> مراجعة الجودة</div>
        <div class="cl-item"><span class="cl-box"></span> جاهز للتسليم ✓</div>
      </div>

    </div>
    <% }) %>
    </div>
  </div>
<% }) %>
</div>

<% } %>

<script>
// ── Generate QR codes ──
document.querySelectorAll('canvas.qr-canvas').forEach(function(canvas) {
  const code = canvas.getAttribute('data-code');
  const wrap  = canvas.closest('.print-grid');
  const is16  = document.getElementById('main-wrap') && document.getElementById('main-wrap').classList.contains('layout-16');
  const size  = is16 ? 60 : 72;
  QRCode.toCanvas(canvas, code, { width:size, margin:1, errorCorrectionLevel:'M' }, function(){});
});

// ── Layout toggle (client-side, no round-trip) ──
function setLayout(n) {
  const url = new URL(window.location.href);
  url.searchParams.set('layout', n);
  window.location.href = url.toString();
}

// ── Auto-print ──
if (new URLSearchParams(window.location.search).get('autoprint') === '1') {
  setTimeout(() => window.print(), 1000);
}
</script>
</body>
</html>
