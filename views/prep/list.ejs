<%- include('../partials/head', {title: 'قوائم التجهيز'}) %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="page-title mb-0">🗂️ قوائم التجهيز</h4>
  <a href="/prep/print-all" class="btn btn-sm btn-outline-secondary" target="_blank">🖨️ طباعة الكل</a>
</div>

<!-- Filters -->
<form method="GET" action="/prep" class="bg-white rounded-3 p-3 shadow-sm mb-3">
  <div class="row g-2 align-items-end">
    <div class="col-6 col-md-3">
      <label class="form-label small fw-bold mb-1">المشغل</label>
      <select class="form-select form-select-sm" name="workshop_id">
        <option value="">الكل</option>
        <% workshops.forEach(function(w){ %>
          <option value="<%= w.id %>" <%= (filters.workshop_id===w.id)?'selected':'' %>><%= w.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-6 col-md-2">
      <label class="form-label small fw-bold mb-1">التاريخ</label>
      <input class="form-control form-control-sm" type="date" name="date" value="<%= filters.date||'' %>">
    </div>
    <div class="col-6 col-md-3">
      <label class="form-label small fw-bold mb-1">المنتج</label>
      <select class="form-select form-select-sm" name="product_id">
        <option value="">الكل</option>
        <% products.forEach(function(p){ %>
          <option value="<%= p.id %>" <%= (filters.product_id===p.id)?'selected':'' %>><%= p.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-6 col-md-2">
      <label class="form-label small fw-bold mb-1">المقاس</label>
      <input class="form-control form-control-sm" name="size" value="<%= filters.size||'' %>" placeholder="المقاس">
    </div>
    <div class="col-12 col-md-2 d-flex gap-2">
      <button class="btn btn-sm btn-brand flex-grow-1">تصفية</button>
      <a href="/prep" class="btn btn-sm btn-outline-secondary">مسح</a>
    </div>
  </div>
</form>

<% if (!orders.length) { %>
  <div class="alert alert-info text-center">لا توجد طلبات تطابق الفلتر الحالي.</div>
<% } else { %>

<form method="POST" action="/prep/print" target="_blank">
  <!-- Toolbar -->
  <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-2">
      <span class="text-muted small"><%= orders.length %> طلب</span>
      <label class="d-flex align-items-center gap-1 small mb-0" style="cursor:pointer">
        <input type="checkbox" onclick="toggleAll(this)" id="check-all"> تحديد الكل
      </label>
    </div>
    <button class="btn btn-sm btn-brand" type="submit">🖨️ طباعة بطاقات المحدد</button>
  </div>

  <!-- Desktop table -->
  <div class="table-responsive bg-white rounded-3 shadow-sm d-none d-md-block">
    <table class="table table-sm table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th style="width:36px"></th>
          <th>رقم الطلب</th>
          <th>الحالة</th>
          <th>القطع</th>
          <th>التاريخ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      <% orders.forEach(function(o){ %>
        <tr>
          <td class="text-center"><input type="checkbox" class="order-check" name="order_ids" value="<%= o.id %>"></td>
          <td><strong><%= o.order_number %></strong></td>
          <td><span class="badge bg-<%= STATUS_COLORS[o.status]||'secondary' %> badge-status"><%= o.status %></span></td>
          <td>
            <div class="d-flex flex-wrap gap-1">
            <% o.items.forEach(function(it){ %>
              <span class="badge bg-light text-dark border" style="font-size:.7rem;"><%= it.product_name %> · <%= it.size||'—' %> · <%= it.qty %></span>
            <% }) %>
            </div>
          </td>
          <td class="text-muted small"><%= new Date(o.created_at).toLocaleDateString('ar-SA') %></td>
          <td>
            <div class="d-flex gap-1">
              <a href="/orders/<%= o.id %>" class="btn btn-sm btn-outline-secondary">فتح</a>
              <a href="/orders/<%= o.id %>/print" class="btn btn-sm btn-outline-secondary" target="_blank">🖨️</a>
            </div>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile cards -->
  <div class="d-md-none">
    <% orders.forEach(function(o){ %>
    <div class="bg-white rounded-3 shadow-sm p-3 mb-2">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <div class="d-flex align-items-center gap-2">
          <input type="checkbox" class="order-check" name="order_ids" value="<%= o.id %>" style="width:20px;height:20px">
          <strong class="fs-6"><%= o.order_number %></strong>
        </div>
        <span class="badge bg-<%= STATUS_COLORS[o.status]||'secondary' %> badge-status"><%= o.status %></span>
      </div>
      <div class="d-flex flex-wrap gap-1 mb-2">
        <% o.items.forEach(function(it){ %>
          <span class="badge bg-light text-dark border" style="font-size:.72rem;">
            <%= it.product_name %> · <%= it.size||'—' %> · x<%= it.qty %>
          </span>
        <% }) %>
      </div>
      <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted small"><%= new Date(o.created_at).toLocaleDateString('ar-SA') %></span>
        <div class="d-flex gap-2">
          <a href="/orders/<%= o.id %>" class="btn btn-sm btn-outline-secondary">فتح</a>
          <a href="/orders/<%= o.id %>/print" class="btn btn-sm btn-outline-secondary" target="_blank">🖨️</a>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="mt-3 d-flex justify-content-end no-print">
    <button class="btn btn-brand" type="submit">🖨️ طباعة بطاقات المحدد</button>
  </div>
</form>
<% } %>

<%- include('../partials/foot') %>
