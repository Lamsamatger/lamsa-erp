<%- include('../partials/head', {title: 'المطرزين'}) %>
<h4 class="page-title">المطرزين</h4>

<% if (pendingJobs.length > 0) { %>
<div class="bg-white rounded shadow-sm mb-4 p-3">
  <h5 class="mb-3">
    طلبات بانتظار تعيين مطرز
    <span class="badge bg-danger ms-2"><%= pendingJobs.length %></span>
  </h5>
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>رقم الطلب</th>
          <th>العميل</th>
          <th>الكمية</th>
          <th>تاريخ الإضافة</th>
          <th>تعيين مطرز</th>
        </tr>
      </thead>
      <tbody>
      <% pendingJobs.forEach(function(job){ %>
        <tr>
          <td>
            <a href="/orders/<%= job.order_id %>" class="fw-bold text-decoration-none"><%= job.order_number %></a>
          </td>
          <td class="text-muted small"><%= job.customer_name || '—' %></td>
          <td><%= job.received_qty %></td>
          <td class="text-muted small"><%= new Date(job.created_at).toLocaleDateString('ar-SA') %></td>
          <td>
            <form method="POST" action="/embroiderers/assign-pending" class="d-flex gap-2 align-items-center">
              <input type="hidden" name="job_id" value="<%= job.id %>">
              <select name="embroiderer_id" class="form-select form-select-sm" style="min-width:160px" required>
                <option value="">اختر مطرزاً…</option>
                <% embroiderers.forEach(function(e){ %>
                  <option value="<%= e.id %>"><%= e.name %></option>
                <% }) %>
              </select>
              <button class="btn btn-sm btn-brand">تعيين</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="row g-3 mb-4">
<% embroiderers.forEach(function(e){ %>
  <div class="col-md-4">
    <a href="/embroiderers/<%= e.id %>" class="text-decoration-none">
    <div class="bg-white rounded p-3 shadow-sm h-100">
      <h6><%= e.name %></h6>
      <p class="small mb-1">سعر القطعة: <strong><%= e.price_per_piece %> ر.س</strong></p>
      <p class="small mb-0">عدد المهام: <%= e.jobsCount %> · منجز: <%= e.totalDone %> · أخطاء: <%= e.totalErrors %></p>
    </div>
    </a>
  </div>
<% }) %>
</div>

<div class="bg-white rounded p-3 shadow-sm" style="max-width:500px">
  <h6>إضافة مطرز جديد</h6>
  <form method="POST" action="/embroiderers/new">
    <input class="form-control mb-2" name="name" placeholder="اسم المطرز" required>
    <input class="form-control mb-2" name="price_per_piece" type="number" step="0.01" placeholder="سعر القطعة">
    <button class="btn btn-brand">إضافة</button>
  </form>
</div>
<%- include('../partials/foot') %>
