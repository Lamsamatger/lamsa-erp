<%- include('../partials/head', {title: 'المشاغل'}) %>
<h4 class="page-title">المشاغل</h4>

<div class="row g-3 mb-4">
<% workshops.forEach(function(w){ %>
  <div class="col-md-4">
    <a href="/workshops/<%= w.id %>" class="text-decoration-none">
    <div class="bg-white rounded p-3 shadow-sm h-100">
      <h6><%= w.name %></h6>
      <p class="text-muted small mb-1">📞 <%= w.phone || '—' %></p>
      <p class="small mb-1">سعر القطعة: <strong><%= w.price_per_piece %> ر.س</strong></p>
      <p class="small mb-0">عدد المهام: <%= w.jobsCount %> · قيد التنفيذ: <%= w.pending %></p>
    </div>
    </a>
  </div>
<% }) %>
</div>

<div class="bg-white rounded p-3 shadow-sm" style="max-width:500px">
  <h6>إضافة مشغل جديد</h6>
  <form method="POST" action="/workshops/new">
    <input class="form-control mb-2" name="name" placeholder="اسم المشغل" required>
    <input class="form-control mb-2" name="phone" placeholder="رقم التواصل">
    <input class="form-control mb-2" name="price_per_piece" type="number" step="0.01" placeholder="سعر القطعة">
    <button class="btn btn-brand">إضافة</button>
  </form>
</div>
<%- include('../partials/foot') %>
